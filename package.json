{
  "name": "fortepan",
  "version": "1.0.0",
  "description": "Fortepan.hu public dev repository",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf _dist src/data/manifest-js.json src/data/manifest-css.json",
    "import-autocomplete-data": "node scripts/import-autocomplete-data",
    "import-rss-data": "node scripts/import-rss-data",
    "eleventy": "npx eleventy",
    "eleventy:serve": "npx eleventy --serve",
    "webpack": "webpack",
    "webpack:serve": "webpack -- --watch",
    "postcss": "postcss 'src/scss/styles.scss' --verbose --dir _dist/css/ --ext css",
    "postcss:serve": "npm run postcss -- --watch",
    "tinacms": "npx tinacms build",
    "tinacms:serve": "npx tinacms dev",
    "build": "ENV=production npm-run-all clean import-autocomplete-data import-rss-data webpack postcss eleventy",
    "dev": "ENV=development npm-run-all -l --silent clean import-autocomplete-data import-rss-data webpack postcss --parallel *:serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fortepan/fortepan.hu.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fortepan/fortepan.hu/issues"
  },
  "homepage": "https://github.com/fortepan/fortepan.hu#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@csstools/postcss-sass": "^5.1.1",
    "@elastic/elasticsearch": "^7.17.14",
    "autoprefixer": "10.4.27",
    "caniuse-lite": "^1.0.30001780",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^13.0.6",
    "html-minifier-terser": "^7.2.0",
    "latest-version": "^9.0.0",
    "netlify-cli": "^24.3.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-hash": "^3.0.0",
    "postcss-import": "^16.1.1",
    "postcss-import-ext-glob": "^2.1.1",
    "postcss-inline-svg": "^6.0.0",
    "postcss-minify": "^1.2.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "terser": "^5.46.1",
    "terser-webpack-plugin": "5.4.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.1",
    "webpack-manifest-plugin": "^6.0.1"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/stimulus-webpack-helpers": "^1.0.1",
    "@tinacms/cli": "^2.1.10",
    "lodash": "^4.17.23",
    "markdown-it": "^14.1.1",
    "rss-parser": "^3.13.0",
    "tinacms": "^3.7.1"
  }
}