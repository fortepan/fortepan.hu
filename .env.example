# Copy to .env for local builds and netlify dev (never commit .env).
# Rotate credentials if they were ever committed to git.

# --- Legacy (optional) ---

# Not used by current frontend; kept for older local setups
API_URL=/api-search

# --- Elasticsearch (required for npm run build and search via elastic-proxy) ---

# Production cluster — used by import-autocomplete-data.js and /api/elastic/prod/*
ELASTIC_HOST=https://elastic.fortepan.hu
ELASTIC_AUTH=reader:your-production-password
# Legacy split form (not read by app; keep in sync with ELASTIC_AUTH if you use both)
ELASTIC_USER=reader
ELASTIC_PASS=your-production-password

# Develop cluster — used by /api/elastic/dev/* when ?dev=1 / isDev localStorage
ELASTIC_HOST_DEV=https://elastic-develop.fortepan.hu
ELASTIC_AUTH_DEV=reader:your-production-password
# Legacy split form (not read by app; keep in sync with ELASTIC_AUTH_DEV if you use both)
ELASTIC_DEV_USER=reader
ELASTIC_DEV_PASS=your-production-password

# --- Tina CMS (required for npm run tinacms / tinacms:serve) ---

# From Tina Cloud project settings (tina/config.js)
TINA_CLIENT_ID=your-tina-client-id
TINA_TOKEN=your-tina-read-token
